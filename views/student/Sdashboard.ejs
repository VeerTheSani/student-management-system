<%- include('../include/_Shead') %>
    <% const resultsData=Array.isArray(results) ? results : []; const latestResult=resultsData.length ?
        resultsData[resultsData.length - 1] : {}; %>
        <div class="flex-1">

            <header class="flex justify-between items-center bg-white shadow p-4">
                <button id="menuBtn" class="md:hidden text-2xl">☰</button>
                <h1 class="text-xl font-semibold">Student Dashboard</h1>
                <div class="flex items-center gap-4">
                    <input type="text" placeholder="Search..." class="border rounded-lg px-3 py-1 w-40 md:w-64">
                    <img src="https://picsum.photos/300/300" class="rounded-full w-10 h-10 object-cover">
                </div>
            </header>
            <main class="p-6 bg-gray-100 max-h-screen space-y-6">

                <section class="grid md:grid-cols-2 gap-6">

                    <div class="bg-white p-6 rounded-xl shadow">
                        <h2 class="text-lg font-semibold mb-4">Grade Distribution</h2>
                        <div class="w-full h-64">
                            <canvas id="myChart"></canvas>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow">
                        <h2 class="text-lg font-semibold mb-4">LeaderBoard</h2>
                        <div class="overflow-x-auto">
                            <table class="w-full border">
                                <thead class="bg-gray-200">
                                    <tr>
                                        <th class="px-4 py-2 border">Name</th>
                                        <th class="px-4 py-2 border">Enrollment No</th>
                                        <th class="px-4 py-2 border">results</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="text-center hover:bg-gray-50">

                                        <td class="border px-4 py-2">
                                            <%= student.name %>
                                        </td>

                                        <td class="border px-4 py-2">
                                            <%= student.enroll %>
                                        </td>

                                        <td
                                            class="border px-4 py-2 font-semibold <%= latestResult && latestResult.resultStatus === 'Pass' ? 'text-green-600' : 'text-red-600' %>">
                                            <%= latestResult && latestResult.resultStatus ? latestResult.resultStatus
                                                : "Pending" %>
                                        </td>
                                    </tr>
                                </tbody>

                            </table>
                        </div>
                    </div>

                </section>
                <section class="grid md:grid-cols-2 gap-6">


                    <div class="bg-white p-3 rounded-xl shadow">
                        <h2 class="text-lg font-semibold mb-4">Credits Progress</h2>
                        <div class="w-full h-64">
                            <canvas id="creditChart"></canvas>
                        </div>
                    </div>

                    <div class="bg-white p-3 rounded-xl shadow">
                        <h2 class="text-lg font-semibold mb-4">Subject Marks</h2>
                        <div class="w-full h-64">
                            <canvas id="marksChart"></canvas>
                        </div>
                    </div>
                </section>

            </main>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script> ## i have added this for markdown support in ai chat, if it works then it works

        <script>
            const resultsData = JSON.parse('<%- JSON.stringify(results || []) %>');
            const latestResult = resultsData.length ? resultsData[resultsData.length - 1] : {};
            const subjectMarks = latestResult.subjects || [];
        </script>

        <script>
            const btnOpen = document.getElementById('menuBtn')
            const btnClose = document.getElementById('closeBtn')
            const slider = document.getElementById('sidebar')
            if (btnOpen) {
                btnOpen.addEventListener("click", () => {
                    slider.classList.remove("-translate-x-full");
                });
            }

            if (btnClose) {
                btnClose.addEventListener("click", () => {
                    slider.classList.add("-translate-x-full");
                });
            }

            const ctx = document.getElementById('myChart');

            if (ctx && subjectMarks.length > 0) {

                const labels = subjectMarks.map(s => s.subject);
                const marks = subjectMarks.map(s => s.marks);

                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Marks Distribution',
                            data: marks,
                            backgroundColor: [
                                '#4f46e5',
                                '#10b981',
                                '#f59e0b',
                                '#ef4444',
                                '#6366f1'
                            ]
                        }]
                    }
                });

            }

            const marksCtx = document.getElementById('marksChart');

            if (marksCtx && subjectMarks.length > 0) {

                const subjects = subjectMarks.map(s => s.subject);
                const marks = subjectMarks.map(s => s.marks);

                new Chart(marksCtx, {
                    type: 'bar',
                    data: {
                        labels: subjects,
                        datasets: [{
                            label: 'Marks',
                            data: marks,
                            backgroundColor: '#4f46e5'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 100
                            }
                        }
                    }
                });

            }

            const gpaCtx = document.getElementById("gpaChart");

            if (gpaCtx && resultsData.length > 0) {

                const sem = resultsData.map(r => "Sem " + r.sem);
                const gpa = resultsData.map(r => r.CGPA);

                new Chart(gpaCtx, {
                    type: 'line',
                    data: {
                        labels: sem,
                        datasets: [{
                            label: 'GPA',
                            data: gpa,
                            borderColor: '#10b981',
                            fill: false
                        }]
                    }
                });
            }
            const statusCtx = document.getElementById("statusChart");

            if (statusCtx) {

                new Chart(statusCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Pass', 'Fail'],
                        datasets: [{
                            data: [
                                latestResult && latestResult.resultStatus === 'Pass' ? 1 : 0,
                                latestResult && latestResult.resultStatus === 'Fail' ? 1 : 0
                            ],
                            backgroundColor: [
                                '#10b981',
                                '#ef4444'
                            ]
                        }]
                    }
                });

            }

            const creditCtx = document.getElementById("creditChart");

            if (creditCtx) {

                new Chart(creditCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Completed', 'Remaining'],
                        datasets: [{
                            data: [
                                latestResult ? latestResult.creditsEarned : 0,
                                160 - (latestResult ? latestResult.creditsEarned : 0)
                            ],
                            backgroundColor: [
                                '#4f46e5',
                                '#e5e7eb'
                            ]
                        }]
                    }
                });

            }
        </script>

<!-- chatbott ui (painn) -->
<div id="chat-widget" style="position:fixed; bottom:24px; right:24px; z-index:1000; font-family:inherit;">

    <button onclick="toggleChat()" id="chat-toggle"
        style="width:56px; height:56px; border-radius:50%; background:#4f46e5; color:white; border:none; cursor:pointer; box-shadow:0 4px 20px rgba(79,70,229,0.4); font-size:22px; display:flex; align-items:center; justify-content:center; margin-left:auto; transition:transform 0.2s;"
        onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
        💬
    </button>

    <div id="chat-box"
        style="display:none; width:340px; background:white; border-radius:16px; box-shadow:0 8px 40px rgba(0,0,0,0.15); overflow:hidden; margin-bottom:12px; position:absolute; bottom:68px; right:0;">


        <div style="background:#4f46e5; padding:16px 20px; display:flex; align-items:center; justify-content:space-between;">
            <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:36px; height:36px; background:rgba(255,255,255,0.2); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px;">🤖</div>
                <div>
                    <div style="color:white; font-weight:600; font-size:14px;">AI Academic Assistant</div>
                    <div style="color:rgba(255,255,255,0.7); font-size:11px;">Ask about your results</div>
                </div>
            </div>
            <button onclick="toggleChat()" style="background:none; border:none; color:white; cursor:pointer; font-size:18px; opacity:0.7;">✕</button>
        </div>


        <div id="chat-messages"
            style="height:300px; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:10px; background:#f9fafb;">
            <div style="background:white; border-radius:12px; padding:10px 14px; font-size:13px; color:#374151; box-shadow:0 1px 4px rgba(0,0,0,0.06); max-width:85%;">
                👋 Hi! I'm your academic assistant. Ask me anything about your results or how to improve!
            </div>
        </div>

    
        <div style="padding:12px 16px; background:white; border-top:1px solid #e5e7eb; display:flex; gap:8px;">
            <input id="chat-input" type="text" placeholder="Type your question..."
                style="flex:1; border:1px solid #e5e7eb; border-radius:10px; padding:8px 12px; font-size:13px; outline:none; color:#374151;"
                onfocus="this.style.borderColor='#4f46e5'" onblur="this.style.borderColor='#e5e7eb'" />
            <button onclick="sendMessage()"
                style="background:#4f46e5; color:white; border:none; border-radius:10px; padding:8px 14px; cursor:pointer; font-size:13px; font-weight:600; transition:background 0.2s;"
                onmouseover="this.style.background='#4338ca'" onmouseout="this.style.background='#4f46e5'">
                Send
            </button>
        </div>
    </div>
</div>

<script>
    function toggleChat() {
        const box = document.getElementById('chat-box')
        box.style.display = box.style.display === 'none' ? 'block' : 'none'
    }

    async function sendMessage() {
        const input = document.getElementById('chat-input')
        const messages = document.getElementById('chat-messages')
        const message = input.value.trim()
        if (!message) return

        // user/studentt message
        messages.innerHTML += `
            <div style="display:flex; justify-content:flex-end;">
                <div style="background:#4f46e5; color:white; border-radius:12px; padding:10px 14px; font-size:13px; max-width:85%;">${message}</div>
            </div>`
        input.value = ''
        messages.scrollTop = messages.scrollHeight

        
        messages.innerHTML += `<div id="typing" style="background:white; border-radius:12px; padding:10px 14px; font-size:13px; color:#9ca3af; box-shadow:0 1px 4px rgba(0,0,0,0.06); max-width:85%;">Typing...</div>`
        messages.scrollTop = messages.scrollHeight

        try {
            const res = await fetch('/chatt', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            })
            const data = await res.json()

            document.getElementById('typing').remove()

            // messages.innerHTML += `
            //     <div style="background:white; border-radius:12px; padding:10px 14px; font-size:13px; color:#374151; box-shadow:0 1px 4px rgba(0,0,0,0.06); max-width:85%;">${data.reply}</div>`
            messages.innerHTML += `
                    <div style="background:white; border-radius:12px; padding:10px 14px; font-size:13px; color:#374151; box-shadow:0 1px 4px rgba(0,0,0,0.06); max-width:90%;">${marked.parse(data.reply)}</div>`
        } catch (err) {
            document.getElementById('typing').remove()
            messages.innerHTML += `<div style="background:white; border-radius:12px; padding:10px 14px; font-size:13px; color:#ef4444; max-width:85%;">Something went wrong. Try again.</div>`
        }

        messages.scrollTop = messages.scrollHeight
    }

    document.getElementById('chat-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') sendMessage()
    })
</script>