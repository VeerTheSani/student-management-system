#acad-chat .fab { width:52px;height:52px;border-radius:16px;background:#0f3d1f;border:1px solid #1a3620;color:#6bda8e;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;transition:all 0.2s;box-shadow:0 4px 24px rgba(15,61,31,0.5);margin-left:auto; }
#acad-chat .fab:hover { background:#1b6b2f;transform:scale(1.05); }
#acad-chat .sched-bar { display:none;background:#071a0d;border-top:1px solid #111f13;padding:8px 14px;flex-shrink:0;font-family:'DM Mono',monospace;font-size:10px;color:#6bda8e;align-items:center;gap:8px; }
#acad-chat .sched-bar.on { display:flex; }
#acad-chat .sched-dot { width:6px;height:6px;border-radius:50%;background:#6bda8e;animation:pulse 1s ease-in-out infinite; }
@keyframes slideIn { from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)} }
