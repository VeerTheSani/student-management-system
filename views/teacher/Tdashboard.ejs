<div class="cb" id="acad-cb">
  <div class="hdr">
    <div class="hdr-left">
      <div class="av">📊</div>
      <div>
        <div class="htitle">Class AI Assistant</div>
        <div class="hsub">● CONNECTED · student_mgm2</div>
      </div>
    </div>
    <button class="close-btn" onclick="acadToggle()">✕</button>
  </div>

  <div class="msgs" id="acad-msgs">
    <div class="msg-ai">👋 Hi! Ask me anything about your class performance, or enable <strong>Schedule Mode</strong> to arrange a meeting.</div>
  </div>

  <div class="sched-bar" id="sched-bar">
    <div class="sched-dot"></div>
    <span>Schedule mode active — describe the meeting you want to arrange</span>
  </div>

  <div class="chips">
    <button class="chip" onclick="quickAsk('Who are the weakest students?')">😟 Weakest</button>
    <button class="chip" onclick="quickAsk('Who has the highest CGPA?')">🏆 Top student</button>
    <button class="chip" onclick="quickAsk('How many students failed?')">❌ Failed</button>
    <button class="chip" onclick="quickAsk('Which subject has the lowest average marks?')">📉 Weak subject</button>
    <button class="chip" onclick="quickAsk('Give me a full class performance summary')">📋 Summary</button>
    <button class="chip sched-chip" id="sched-toggle" onclick="toggleSchedMode()">📅 Schedule meeting</button>
  </div>

  <div class="footer">
    <input class="inp" id="acad-inp" type="text" placeholder="Ask about your class..." />
    <button class="send-btn" id="acad-send" onclick="acadSend()">Send ↑</button>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
<script>
var _schedMode = false;
var _busy = false;

function acadToggle() {
  var cb = document.getElementById('acad-cb');
  cb.classList.toggle('open');
}

function toggleSchedMode() {
  _schedMode = !_schedMode;
  var btn = document.getElementById('sched-toggle');
  var bar = document.getElementById('sched-bar');
  var inp = document.getElementById('acad-inp');
  if (_schedMode) {
    btn.classList.add('active');
    bar.classList.add('on');
    inp.placeholder = 'e.g. Schedule a parent meeting for Monday at 10am...';
  } else {
    btn.classList.remove('active');
    bar.classList.remove('on');
    inp.placeholder = 'Ask about your class...';
  }
}

function quickAsk(q) {
  document.getElementById('acad-inp').value = q;
  acadSend();
}

var _CHAT_STEPS = [
  'Connecting to database...',
  'Fetching student records...',
  'Scanning academic data...',
  'Running analysis...',
  'Generating response...'
];

var _SCHED_STEPS = [
  'Parsing meeting details...',
  'Preparing notification...',
  'Calling arrange_meeting()...',
  'Sending to Activepieces...',
  'Notifying students...'
];

function buildTypingNode(isSchedule) {
  var steps = isSchedule ? _SCHED_STEPS : _CHAT_STEPS;
  var wrap = document.createElement('div');
  wrap.className = 'typing-wrap';
  wrap.id = 'acad-typing';

  var lbl = document.createElement('div');
  lbl.className = 'typing-label';
  lbl.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div><span>' + (isSchedule ? 'Scheduling meeting' : 'Analyzing') + '</span>';
  wrap.appendChild(lbl);

  var stepsDiv = document.createElement('div');
  stepsDiv.className = 'steps';

  steps.forEach(function(s, i) {
    var stepEl = document.createElement('div');
    stepEl.className = 'step';
    stepEl.id = 'step-' + i;
    stepEl.innerHTML = '<div class="step-icon"></div><span>' + s + '</span>';
    stepsDiv.appendChild(stepEl);
  });

  if (isSchedule) {
    var tc = document.createElement('div');
    tc.className = 'tool-card';
    tc.id = 'tool-preview';
    tc.style.display = 'none';
    tc.innerHTML = '<div class="tc-label">tool call · arrange_meeting</div><div class="tool-row">📅 <span id="tc-date">--</span></div><div class="tool-row">⏰ <span id="tc-time">--</span></div><div class="tool-row">📝 <span id="tc-topic">--</span></div>';
    stepsDiv.appendChild(tc);
  }

  wrap.appendChild(stepsDiv);
  return wrap;
}

function animateSteps(total, delay, cb) {
  var i = 0;
  function next() {
    if (i > 0) {
      var prev = document.getElementById('step-' + (i-1));
      if (prev) { prev.classList.remove('active'); prev.classList.add('done'); prev.querySelector('.step-icon').innerHTML = '✓'; }
    }
    if (i < total) {
      var cur = document.getElementById('step-' + i);
      if (cur) cur.classList.add('active');
      i++;
      setTimeout(next, delay);
    } else {
      if (cb) cb();
    }
  }
  next();
}

async function acadSend() {
  if (_busy) return;
  var inp = document.getElementById('acad-inp');
  var msgs = document.getElementById('acad-msgs');
  var sendBtn = document.getElementById('acad-send');
  var msg = inp.value.trim();
  if (!msg) return;

  _busy = true;
  sendBtn.disabled = true;

  var userEl = document.createElement('div');
  userEl.className = 'msg-user';
  userEl.textContent = msg;
  msgs.appendChild(userEl);
  inp.value = '';
  msgs.scrollTop = msgs.scrollHeight;

  var isSchedule = _schedMode;
  var typingNode = buildTypingNode(isSchedule);
  msgs.appendChild(typingNode);
  msgs.scrollTop = msgs.scrollHeight;

  var stepDelay = isSchedule ? 500 : 350;
  var stepCount = isSchedule ? _SCHED_STEPS.length : _CHAT_STEPS.length;

  var fetchDone = false;
  var animDone = false;
  var replyData = null;

  animateSteps(stepCount, stepDelay, function() {
    animDone = true;
    if (fetchDone) showReply(replyData, isSchedule, msgs, sendBtn);
  });

  try {
    var res = await fetch('/tchatt', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: msg, mode: isSchedule ? 'schedule' : 'chat' })
    });
    var data = await res.json();
    fetchDone = true;
    replyData = data;
    if (animDone) showReply(data, isSchedule, msgs, sendBtn);
  } catch(e) {
    fetchDone = true;
    replyData = { reply: 'Connection failed. Check the server.' };
    if (animDone) showReply(replyData, isSchedule, msgs, sendBtn);
  }
}

function showReply(data, isSchedule, msgs, sendBtn) {
  var typing = document.getElementById('acad-typing');
  if (typing) typing.remove();

  var reply = (data && data.reply) ? data.reply : 'Something went wrong.';

  var el = document.createElement('div');
  el.className = 'msg-ai';

  if (isSchedule && reply.startsWith('✅')) {
    el.innerHTML = '<div style="font-family:\'DM Mono\',monospace;font-size:11px;color:#6bda8e;line-height:1.7;">' + reply.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>') + '</div>';
  } else {
    el.innerHTML = marked.parse(reply);
  }

  msgs.appendChild(el);
  msgs.scrollTop = msgs.scrollHeight;
  _busy = false;
  sendBtn.disabled = false;
}

document.getElementById('acad-inp').addEventListener('keypress', function(e) {
  if (e.key === 'Enter') acadSend();
});
</script>
</div>


